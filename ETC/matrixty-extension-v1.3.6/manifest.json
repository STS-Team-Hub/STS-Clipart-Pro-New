{
  "manifest_version": 3,
  "name": "Matrixty Extension",
  "version": "1.3.6",
  "description": "v1.3.6 — Fix clipart sync hanging at 'Syncing...' (canvas-taint hardening, fetchAsDataUrl timeout, route cross-origin imageUrl through background)",
  "permissions": [
    "activeTab",
    "storage",
    "unlimitedStorage",
    "tabs",
    "clipboardWrite",
    "clipboardRead",
    "scripting",
    "debugger"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "content.js",
        "listing.js"
      ],
      "css": [
        "content.css"
      ]
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}